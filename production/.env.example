# Wergonic Production Environment Variables
# Copy this file to .env and fill in the values

# Server port (default: 3000)
PORT=3000

# Environment (development or production)
NODE_ENV=production

# Session secret - CHANGE THIS to a random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-secret-here-change-this

# Password hash - Generate with: npm run hash-password
# This is the bcrypt hash of your login password
APP_PASSWORD_HASH=$2b$10$your-bcrypt-hash-here
